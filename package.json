{
  "name": "@lockisecurity/crypto-core",
  "version": "1.0.0",
  "description": "AES-256-GCM encryption utilities used by Locki — encrypt text and files in-browser with the [LOCKI:v2:] format",
  "keywords": [
    "aes-gcm",
    "aes-256",
    "encryption",
    "webcrypto",
    "locki"
  ],
  "license": "MIT",
  "homepage": "https://lockisecurity.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/locki-hub/locki-crypto.git"
  },
  "bugs": {
    "url": "https://github.com/locki-hub/locki-crypto/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.x"
  }
}
